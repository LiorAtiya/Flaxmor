# ============================================================
# Copy this file to `.env` and fill in the values:
#     cp env.example .env
# `.env` is gitignored — real secrets never enter the repo.
# ============================================================

# --- REQUIRED (secret) --------------------------------------
# Your OpenAI API key. The middleware authenticates with this
# server-side key; client keys are never trusted or forwarded.
OPENAI_API_KEY=sk-REPLACE_ME

# --- OPTIONAL (defaults shown, uncomment to override) -------

# OpenAI-compatible upstream base URL.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Models exposed to Open WebUI in GET /v1/models (JSON array).
# SERVED_MODELS=["gpt-4o-mini","gpt-4o"]

# Upstream HTTP timeouts (seconds).
# CONNECT_TIMEOUT_SECONDS=10.0
# READ_TIMEOUT_SECONDS=120.0

# Middleware log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# --- Postgres (used by docker-compose for Open WebUI) -------
# Local-dev credentials; fine for localhost, change for anything shared.
POSTGRES_USER=openwebui
POSTGRES_PASSWORD=openwebui_local_dev
POSTGRES_DB=openwebui
